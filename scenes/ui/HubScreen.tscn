[sub_resource type="Shader" id="VignetteShader"]
code = "shader_type canvas_item;
void fragment() {
    vec2 uv = UV - vec2(0.5);
    float vignette = smoothstep(0.35, 0.75, length(uv));
    COLOR = vec4(0.0, 0.0, 0.0, vignette * 0.55);
}
"

[sub_resource type="ShaderMaterial" id="VignetteMaterial"]
